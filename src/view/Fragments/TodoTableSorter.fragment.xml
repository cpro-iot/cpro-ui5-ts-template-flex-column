<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <ViewSettingsDialog confirm="sortTodos">
        <sortItems>
            <ViewSettingsItem text="{i18n>table-events-column-eventid}" key="userId" selected="true" />
            <ViewSettingsItem text="{i18n>table-events-column-todoId}" key="id" />
            <ViewSettingsItem text="{i18n>table-events-column-todoTitle}" key="title" />
            <ViewSettingsItem text="{i18n>table-events-description}" key="description" />
            <ViewSettingsItem text="{i18n>table-events-column-todoDone}" key="completed" />
        </sortItems>
    </ViewSettingsDialog>
</core:FragmentDefinition>