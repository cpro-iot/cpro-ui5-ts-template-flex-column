<mvc:View controllerName="cpro.ui5.__kunde__.__projekt__.controller.Home" displayBlock="true"
	xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc">
	<Page>
		<customHeader>
			<OverflowToolbar>
				<Image src="assets/logo.jpg" height="30px" />
				<Title text="{i18n>app-title}" />
				<ToolbarSpacer />
				<Button icon="sap-icon://key-user-settings" tooltip="Administration" press="openSettings" />
			</OverflowToolbar>

		</customHeader>

		<content>
			<Table id="table-events" inset="false" items="{event>/collection}">
				<headerToolbar>
					<OverflowToolbar>
						<content>
							<Title text="{i18n>table-events-title}" />
							<ToolbarSpacer />
							<Button type="Transparent" tooltip="{i18n>table-events-toolbar-sort}"
								icon="sap-icon://sort" press="onOpenSorterDialog" />
							<SearchField width="14rem" liveChange="onSearch" />
						</content>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column width="8em" hAlign="Left">
						<Text text="{i18n>table-events-column-eventid}" />
					</Column>
					<Column hAlign="Left" minScreenWidth="Tablet" demandPopin="true">
						<Text text="{i18n>table-events-column-eventId}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true">
						<Text text="{i18n>table-events-column-location}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true" hAlign="Left">
						<Text text="{i18n>table-events-column-attendeeCount}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="onPressTableItem" vAlign="Middle">
						<cells>
							<Text text="{event>eventId}" />
							<ObjectIdentifier title="{event>eventName}" text="{event>description}" />
							<ObjectIdentifier title="{event>date}" text="{event>location}" />
							<ObjectIdentifier title="{= ${event>attendees}.length }" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<OverflowToolbar>
				<Button icon="sap-icon://bell" text="{= ${messages>/collection}.length }"
					visible="{= ${messages>/collection}.length > 0 }" press="toggleMessageManager" />
				<ToolbarSpacer />
				<Button icon="sap-icon://hint" type="Ghost" press="onPressInfoButton" />
				<Button text="{i18n>label-save}" type="Accept" press="onPressSuccessButton" />
				<Button text="{i18n>label-cancel}" type="Reject" press="onPressCancelButton" />
			</OverflowToolbar>
		</footer>
	</Page>
</mvc:View>