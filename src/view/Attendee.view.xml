<mvc:View controllerName="cpro.ui5.__kunde__.__projekt__.controller.Attendee" displayBlock="true"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:layout="sap.ui.layout"
  xmlns:core="sap.ui.core"
  xmlns:mvc="sap.ui.core.mvc">

  <f:DynamicPage id="attendee-page">
    <!-- DynamicPage Title -->
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{event>/activeAttendee/name}" />
        </f:heading>
        <f:expandedContent>
          <Label text="{event>/activeAttendee/registrationStatus}" />
        </f:expandedContent>
        <f:snappedContent>
          <Label text="{event>/activeAttendee/registrationStatus}" />
        </f:snappedContent>
        <f:snappedTitleOnMobile>
          <Title text="{event>/activeAttendee/registrationStatus}" />
        </f:snappedTitleOnMobile>
        <f:content>
          <OverflowToolbar>

          </OverflowToolbar>
        </f:content>
        <f:navigationActions>
          <Button
            icon="sap-icon://full-screen"
            type="Transparent" />
          <Button
            icon="sap-icon://decline"
            type="Transparent"
            press="onCloseAttendeeDetails" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>
    <!-- DynamicPage Header -->
    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <layout:HorizontalLayout allowWrapping="true">
          <layout:VerticalLayout class="sapUiMediumMarginEnd">
            <ObjectAttribute title="Location" text="{event>/activeItem/location}" />
            <ObjectAttribute title="Date" text="{event>/activeItem/date}" />
          </layout:VerticalLayout>
        </layout:HorizontalLayout>
      </f:DynamicPageHeader>
    </f:header>
  </f:DynamicPage>
</mvc:View>